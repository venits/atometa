# ── Assets — keep structure, ignore large binary models ───────────────────
# Commit shaders and icons, but not large GLB/OBJ/FBX files
assets/models/*.glb
assets/models/*.obj
assets/models/*.fbx
assets/models/*.dae
assets/models/*.gltf
# To force-add a small model: git add -f assets/models/placeholder.glb

